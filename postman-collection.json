{
  "info": {
    "_postman_id": "blog-api-collection",
    "name": "Blog API",
    "description": "Scalable Blog Application API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"John Doe\",\"email\": \"john@example.com\",\"password\": \"password123\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"john@example.com\",\"password\": \"password123\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Blogs",
      "item": [
        {
          "name": "Get All Blogs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/blogs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs"]
            }
          }
        },
        {
          "name": "Get Blogs by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/blogs?category=Technology",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs"],
              "query": [
                {
                  "key": "category",
                  "value": "Technology"
                }
              ]
            }
          }
        },
        {
          "name": "Get Blog by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/blogs/BLOG_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs", "BLOG_ID_HERE"]
            }
          }
        },
        {
          "name": "Create Blog",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"My First Blog\",\"content\": \"This is my first blog post about Node.js and Express.\",\"category\": \"Technology\",\"tags\": [\"nodejs\", \"express\", \"api\"]}"
            },
            "url": {
              "raw": "http://localhost:5000/api/blogs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs"]
            }
          }
        },
        {
          "name": "Update Blog",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Updated Title\",\"content\": \"Updated content for the blog post.\"}"
            },
            "url": {
              "raw": "http://localhost:5000/api/blogs/BLOG_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs", "BLOG_ID_HERE"]
            }
          }
        },
        {
          "name": "Delete Blog",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/blogs/BLOG_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs", "BLOG_ID_HERE"]
            }
          }
        },
        {
          "name": "Get My Blogs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/blogs/user/my-blogs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "blogs", "user", "my-blogs"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "health"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ]
}
